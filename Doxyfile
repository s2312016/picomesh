PROJECT_NAME           = PicoMesh
PROJECT_NUMBER         = 0.1.0
PROJECT_BRIEF          = "Fixed-memory building blocks for distributed microcontroller systems"
OUTPUT_DIRECTORY       = build-docs
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
WARN_LOGFILE           = doxygen-warnings.log
INPUT                   = README.md README_ja.md ROADMAP.md CONTRIBUTING.md GOVERNANCE.md MAINTAINERS.md SECURITY.md RELEASING.md include docs ports/pico-sdk/README.md
FILE_PATTERNS           = *.h *.hpp *.md
RECURSIVE               = YES
EXCLUDE_PATTERNS        = */validation/*
USE_MDFILE_AS_MAINPAGE  = docs/api_reference.md
GENERATE_HTML           = YES
HTML_OUTPUT             = html
GENERATE_TREEVIEW       = YES
DISABLE_INDEX           = NO
GENERATE_LATEX           = NO
QUIET                   = YES
